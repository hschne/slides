#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
OUT_DIR="${REPO_ROOT}/out"
CACHE_DIR="${OUT_DIR}/.cache"

VERBOSE=false
FORCE=false

usage() {
  cat <<EOF
Usage: bin/build [--verbose] [--force] [<slide-dir>...]

Build slides into out/<slug>/. Reads slides.yml in each dated directory.
Skips slides whose source hasn't changed since the last build (hash-based).

Options:
  --verbose, -v   Show full output from npm/pnpm commands
  --force, -f     Rebuild all slides regardless of cache

Arguments:
  slide-dir    One or more slide directories to build (optional). Builds all slides if omitted.

Frameworks:
  static   Copy directory as-is (legacy slides with vendored reveal.js)
  revealjs npm install && npm run build → copies dist/ to out/<slug>/
  slidev   pnpm install && pnpm build --base /slides/<slug>/ → copies dist/ to out/<slug>/
EOF
}

hash_dir() {
  find "$1" -type f | sort | xargs sha256sum | sha256sum | cut -d' ' -f1
}

hash_root_files() {
  sha256sum "${REPO_ROOT}/bin/build" "${REPO_ROOT}/mise.toml" 2>/dev/null \
    | sha256sum | cut -d' ' -f1
}

check_root_changed() {
  local hash_file="${CACHE_DIR}/root.hash"
  local current_hash
  current_hash=$(hash_root_files)

  if [[ -f "$hash_file" ]] && [[ "$(cat "$hash_file")" == "$current_hash" ]]; then
    return 1 # not changed
  fi

  echo "$current_hash" > "$hash_file"
  return 0 # changed
}

clean_deleted_slides() {
  for out_slug_dir in "${OUT_DIR}"/*/; do
    [[ -d "$out_slug_dir" ]] || continue
    local slug
    slug=$(basename "$out_slug_dir")
    [[ "$slug" == ".cache" ]] && continue

    local found=false
    for slide_dir in "${REPO_ROOT}"/[0-9][0-9]-*/; do
      [[ -d "$slide_dir" ]] || continue
      local slide_yml="${slide_dir}/slides.yml"
      [[ -f "$slide_yml" ]] || continue
      if [[ "$(yq '.slug' "$slide_yml")" == "$slug" ]]; then
        found=true
        break
      fi
    done

    if ! $found; then
      echo "Removing deleted slide: ${slug}"
      rm -rf "$out_slug_dir"
      rm -f "${CACHE_DIR}/${slug}.hash"
    fi
  done
}

build_slide() {
  local slide_dir="$1"
  local force_build="${2:-false}"
  local slide_yml="${slide_dir}/slides.yml"

  local slug framework
  slug=$(yq '.slug' "$slide_yml")
  framework=$(yq '.framework' "$slide_yml")

  # Check cache
  local hash_file="${CACHE_DIR}/${slug}.hash"
  local current_hash
  current_hash=$(hash_dir "$slide_dir")

  if ! $force_build && [[ -f "$hash_file" ]] && [[ "$(cat "$hash_file")" == "$current_hash" ]]; then
    echo "Skipping: ${slug} (unchanged)"
    return 1
  fi

  local out_dir="${OUT_DIR}/${slug}"
  mkdir -p "$out_dir"

  echo "Building: ${slug} (${framework})"

  case "$framework" in
    static)
      cp -r "${slide_dir}/." "${out_dir}/"
      rm -f "${out_dir}/slides.yml" "${out_dir}/.node-version"
      ;;
    revealjs)
      (
        cd "$slide_dir"
        if $VERBOSE; then
          npm install
          npm run build
        else
          npm install --silent
          npm run build --silent
        fi
        cp -r dist/. "${out_dir}/"
      )
      ;;
    slidev)
      (
        cd "$slide_dir"
        if $VERBOSE; then
          pnpm install
          pnpm build --base "/slides/${slug}/"
        else
          pnpm install --silent
          pnpm build --base "/slides/${slug}/" > /dev/null 2>&1
        fi
        cp -r dist/. "${out_dir}/"
      )
      ;;
  esac

  echo "$current_hash" > "$hash_file"
  echo "  ✓ ${slug} built successfully"
}

generate_manifest() {
  local manifest="${OUT_DIR}/manifest.json"
  echo "Generating manifest.json"

  for slide_dir in "${REPO_ROOT}"/[0-9][0-9]-*/; do
    local slide_yml="${slide_dir}/slides.yml"
    local dir_name date
    dir_name=$(basename "$slide_dir")
    date=$(echo "$dir_name" | grep -oE '^[0-9]{2}-[0-9]{2}-[0-9]{2}' | sed 's/^\([0-9]\{2\}\)-\([0-9]\{2\}\)-\([0-9]\{2\}\)/20\1-\2-\3/')

    yq -o=json "{\"slug\": .slug, \"title\": .title, \"description\": .description, \"date\": \"${date}\", \"framework\": .framework, \"public\": .public}" "$slide_yml"
  done | jq -s '.' > "$manifest"

  echo "  → out/manifest.json"
}

main() {
  while [[ $# -gt 0 ]]; do
    case "${1:-}" in
      --help|-h) usage; exit 0 ;;
      --verbose|-v) VERBOSE=true; shift ;;
      --force|-f) FORCE=true; shift ;;
      *) break ;;
    esac
  done

  local built=0
  local skipped=0

  mkdir -p "$OUT_DIR" "$CACHE_DIR"

  # Clean output for deleted slide directories
  clean_deleted_slides

  # Check if root build files changed → force rebuild all (only when building all slides)
  local force_build=$FORCE
  if [[ $# -eq 0 ]] && ! $force_build && check_root_changed; then
    echo "Root build files changed — rebuilding all slides"
    force_build=true
  fi

  if [[ $# -gt 0 ]]; then
    for slide_dir in "$@"; do
      if build_slide "$(cd "$slide_dir" && pwd)" "$force_build"; then
        built=$(( built + 1 ))
      else
        skipped=$(( skipped + 1 ))
      fi
    done
  else
    for slide_dir in "${REPO_ROOT}"/[0-9][0-9]-*/; do
      [[ -d "$slide_dir" ]] || continue
      if build_slide "$slide_dir" "$force_build"; then
        built=$(( built + 1 ))
      else
        skipped=$(( skipped + 1 ))
      fi
    done
  fi

  generate_manifest

  echo "Done. Built ${built}, skipped ${skipped} slide(s)."
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
