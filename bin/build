#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
OUT_DIR="${REPO_ROOT}/out"

VERBOSE=false

usage() {
  cat <<EOF
Usage: bin/build [--verbose] [<talk-dir>...]

Build talks into out/<slug>/. Reads talk.yml in each dated directory.

Options:
  --verbose, -v   Show full output from npm/pnpm commands

Arguments:
  talk-dir    One or more talk directories to build (optional). Builds all talks if omitted.

Frameworks:
  static   Copy directory as-is (legacy talks with vendored reveal.js)
  revealjs npm install && npm run build → copies dist/ to out/<slug>/
  slidev   pnpm install && pnpm build --base /talks/<slug>/ → copies dist/ to out/<slug>/
EOF
}

build_talk() {
  local talk_dir="$1"
  local talk_yml="${talk_dir}/talk.yml"

  local slug framework
  slug=$(yq '.slug' "$talk_yml")
  framework=$(yq '.framework' "$talk_yml")

  local out_dir="${OUT_DIR}/${slug}"
  mkdir -p "$out_dir"

  echo "Building: ${slug} (${framework})"

  case "$framework" in
    static)
      cp -r "${talk_dir}/." "${out_dir}/"
      rm -f "${out_dir}/talk.yml" "${out_dir}/.node-version"
      ;;
    revealjs)
      (
        cd "$talk_dir"
        if $VERBOSE; then
          npm install
          npm run build
        else
          npm install --silent
          npm run build --silent
        fi
        cp -r dist/. "${out_dir}/"
      )
      ;;
    slidev)
      (
        cd "$talk_dir"
        if $VERBOSE; then
          pnpm install
          pnpm build --base "/talks/${slug}/"
        else
          pnpm install --silent
          pnpm build --base "/talks/${slug}/" > /dev/null 2>&1
        fi
        cp -r dist/. "${out_dir}/"
      )
      ;;
  esac

  echo "  ✓ ${slug} built successfully"
}

generate_manifest() {
  local manifest="${OUT_DIR}/manifest.json"
  echo "Generating manifest.json"

  for talk_dir in "${REPO_ROOT}"/[0-9][0-9]-*/; do
    local talk_yml="${talk_dir}/talk.yml"
    local dir_name date
    dir_name=$(basename "$talk_dir")
    date=$(echo "$dir_name" | grep -oE '^[0-9]{2}-[0-9]{2}-[0-9]{2}' | sed 's/^\([0-9]\{2\}\)-\([0-9]\{2\}\)-\([0-9]\{2\}\)/20\1-\2-\3/')

    yq -o=json "{\"slug\": .slug, \"title\": .title, \"date\": \"${date}\", \"event\": .event, \"framework\": .framework, \"public\": .public, \"thumbnail\": .thumbnail}" "$talk_yml"
  done | jq -s '.' > "$manifest"

  echo "  → out/manifest.json"
}

main() {
  while [[ $# -gt 0 ]]; do
    case "${1:-}" in
      --help|-h) usage; exit 0 ;;
      --verbose|-v) VERBOSE=true; shift ;;
      *) break ;;
    esac
  done

  local built=0

  mkdir -p "$OUT_DIR"

  if [[ $# -gt 0 ]]; then
    for talk_dir in "$@"; do
      build_talk "$(cd "$talk_dir" && pwd)"
      built=$(( built + 1 ))
    done
  else
    for talk_dir in "${REPO_ROOT}"/[0-9][0-9]-*/; do
      [[ -d "$talk_dir" ]] || continue
      build_talk "$talk_dir"
      built=$(( built + 1 ))
    done
  fi

  generate_manifest

  echo "Done. Built ${built} talk(s)."
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
